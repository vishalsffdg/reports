int irPin = 7;
int relay = 8;

void setup() {
pinMode(irPin, INPUT);
pinMode(relay, OUTPUT);
}

void loop() {
int val = digitalRead(irPin);

if (val == LOW) {
digitalWrite(relay, HIGH); // ON
} else {
digitalWrite(relay, LOW);
}
}

