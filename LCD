#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

int trig = 9;
int echo = 10;
int buzzer = 3;

void setup() {
lcd.begin();
lcd.backlight();

pinMode(trig, OUTPUT);
pinMode(echo, INPUT);
pinMode(buzzer, OUTPUT);

Serial.begin(9600);
}

void loop() {

// Trigger pulse
digitalWrite(trig, LOW);
delayMicroseconds(2);
digitalWrite(trig, HIGH);
delayMicroseconds(10);
digitalWrite(trig, LOW);

// Read echo
long duration = pulseIn(echo, HIGH);

// Convert to distance
float distance = duration * 0.034 / 2;

// Display on LCD
lcd.clear();
lcd.setCursor(0, 0);
lcd.print("Distance:");
lcd.setCursor(0, 1);
lcd.print(distance);
lcd.print(" cm");

Serial.println(distance);

// Condition
if (distance < 5) {
digitalWrite(buzzer, HIGH);
lcd.setCursor(10, 1);
lcd.print("ALERT");
} else {
digitalWrite(buzzer, LOW);
}

delay(500);
}

